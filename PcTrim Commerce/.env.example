# Copy to .env and set real values (do not commit .env)

# === App principal (login, pedidos, etc.) ===
ENVIRONMENT=development
FLASK_SECRET_KEY=replace-with-long-random-string

MYSQL_HOST=92.113.33.100
MYSQL_PORT=3308
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=pctrim_commerce

# Administração da plataforma — logins com acesso a /admin/lojas (separados por vírgula)
# PLATFORM_ADMIN_USERS=joaquim,marcio,suporte

# Credenciais dos dois bancos (Admin > Lojas usa prod e HML para listar/cadastrar)
# MYSQL_DATABASE_PROD=pctrim_commerce
# MYSQL_USER_PROD=root
# MYSQL_PASSWORD_PROD=your_prod_password
# MYSQL_DATABASE_HML=pctrim_commerce_hml
# MYSQL_USER_HML=pctrim_hml
# MYSQL_PASSWORD_HML=your_hml_password

# MYSQL_DATABASE acima: credencial legada / bootstrap local — NÃO define ambiente da loja.
# Só dadosloja.ambiente (Admin > Lojas, gravado nos 2 bancos) define pctrim_commerce vs _hml.

# Base interna PcTrim (cadastro de clientes para nova loja)
# MYSQL_DATABASE_INTERNO=interno
# Se no servidor o MySQL da loja for 127.0.0.1:3306 mas interno estiver em outra porta:
# MYSQL_HOST_INTERNO=127.0.0.1
# MYSQL_PORT_INTERNO=3308
# MYSQL_USER_INTERNO=root
# MYSQL_PASSWORD_INTERNO=sua_senha
# MYSQL_INTERN_CONNECT_TIMEOUT=5

# Aviso de comprovante de pagamento (WhatsApp equipe PcTrim, vírgula)
# FINANCEIRO_AVISO_WHATSAPP=5511971447534,5511971447584

# Produção (servidor Hostinger): veja deploy/env.production.example
# ENVIRONMENT=production
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# FLASK_DEBUG=0
# SESSION_COOKIE_SECURE=1

# Optional
# FLASK_DEBUG=1
# LOG_SESSION_DEBUG=1
# BUSINESS_TYPE=retail

# Local: use apenas UMA instancia na porta 2001
#   powershell -File deploy/run_local.ps1
