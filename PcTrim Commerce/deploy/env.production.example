# Copie para .env no servidor (FileZilla ou SSH). Não commitar .env.
#
# Se o PC já conecta no MySQL do servidor: copie MYSQL_USER, MYSQL_PASSWORD,
# MYSQL_DATABASE (e PORT se souber) do .env local — mas no servidor use:
#   MYSQL_HOST=127.0.0.1   (não use o IP público; o app roda DENTRO do servidor)
#
ENVIRONMENT=production
FLASK_SECRET_KEY=substitua-por-string-longa-aleatoria

# App em https://pedidofacil.online/LojaOnline/ (obrigatorio se Apache usa subpath)
LOJA_URL_PREFIX=/LojaOnline

MYSQL_HOST=127.0.0.1
MYSQL_USER=mesmo_do_seu_env_local
MYSQL_PASSWORD=mesma_do_seu_env_local
MYSQL_PORT=3306
MYSQL_DATABASE=loja2001

FLASK_DEBUG=0
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax

# Logins com acesso a /admin/lojas (separados por virgula)
PLATFORM_ADMIN_USERS=joaquim,joaquim1,marcio,suporte,admin_pctrim

# Ajuste o caminho se a pasta do app no servidor for outra
LOJA_PEDIDOS_SALVOS_DIR=/var/www/html/LojaOnline/data/pedidos_salvos
LOJA_RELATORIOS_DIR=/var/www/html/LojaOnline/data/relatorios

# Obrigatorio se alguma loja estiver com ambiente=homologation no Admin.
# Nao altera o banco padrao da app — so permite conectar em pctrim_commerce_hml
# quando dadosloja.ambiente pedir homologacao (mesma URL de login).
MYSQL_DATABASE_HML=pctrim_commerce_hml
MYSQL_USER_HML=pctrim_hml
MYSQL_PASSWORD_HML=senha_do_usuario_pctrim_hml

# --- WhatsApp (uazapi) — obrigatorio para Criar instancia e login por codigo ---
# UZAPI_URL=https://pctrim.uazapi.com
# UZAPI_ADMIN_TOKEN=token_admin_servidor_uazapi
# UZAPI_TOKEN=token_instancia_plataforma_login_otp
# UZAPI_DDI_PADRAO=55
# Apos alterar: sudo systemctl restart lojaonline
